        "class AgentState(TypedDict):\n",
        "    transcript: str\n",
        "    route: Literal[\"Verification\", \"Loan\", \"CreditCard\", \"Sentiment\"]\n",
        "    verification_result: dict\n",
        "    card_analysis: dict\n",
        "    loan_suggestion: dict\n",
